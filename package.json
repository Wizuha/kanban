{
  "name": "kanban",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:back\" \"npm run dev:front\"",
    "dev:back": "nodemon server/index.js",
    "dev:front": "vite",
    "build": "vite build",
    "test": "vitest",
    "seed": "node server/config/seed.js",
    "test:back": "node --experimental-vm-modules node_modules/.bin/jest server",
    "test:front": "vitest run src/tests"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "bootstrap": "^5.3.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sequelize": "^6.37.8",
    "sequelize-pool": "^8.0.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "babel-jest": "^30.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    }
  }
}
